@startuml
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle

class AssessmentTest {
  test_id: UUID
  subject_code: str
  grade: int
  created_at: datetime
  version: int
}

class Question {
  question_id: UUID
  node_id: str
  text: str
  answer_key: str
  max_score: int
}

class AssignmentAggregate {
  assignment_id: UUID
  test_id: UUID
  child_id: UUID
  status: AssignmentStatus
  assigned_at: datetime
  version: int
}

class AttemptAggregate {
  attempt_id: UUID
  assignment_id: UUID
  child_id: UUID
  status: AttemptStatus
  started_at: datetime
  submitted_at: datetime?
  score: int
  version: int
}

class Answer {
  question_id: UUID
  value: str
  is_correct: bool
  awarded_score: int
}

class Subject {
  code: str
  name: str
}

class Topic {
  code: str
  subject_code: str
  grade: int
  name: str
}

class MicroSkillNode {
  node_id: str
  subject_code: str
  grade: int
  section_code: str
  section_name: str
  micro_skill_name: str
  predecessor_ids: list[str]
  criticality: low|medium|high
  source_ref: str?
}

AssessmentTest "1" o-- "1..*" Question
AssignmentAggregate "1" --> "1" AssessmentTest
AttemptAggregate "1" --> "1" AssignmentAggregate
AttemptAggregate "1" o-- "0..*" Answer
Topic "*" --> "1" Subject
Question "*" --> "1" MicroSkillNode
MicroSkillNode "*" --> "1" Topic
@enduml
